OPENAI_API_KEY=sk-your-key-here
# Recommended for this game (instruction following + hidden state at low cost):
OPENAI_MODEL=gpt-4.1-mini
# Optional override:
# OPENAI_BASE_URL=https://api.openai.com/v1

# Legacy NVIDIA NIM fallback (used only if OPENAI_API_KEY is unset):
# Get a key at https://build.nvidia.com  (starts with "nvapi-")
NIM_API_KEY=nvapi-your-key-here

# Optional overrides:
# Any DeepSeek model available on NVIDIA NIM (note the "deepseek-ai/" prefix).
NIM_MODEL=deepseek-ai/deepseek-v4-pro
# Base URL for the OpenAI-compatible endpoint.
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Supabase (seed sharing). Find these in your project's API settings.
# The publishable/anon key is for client-safe reads only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-key-here
# Server-only. Required in production so seed RPCs can revoke EXECUTE from anon.
# Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
